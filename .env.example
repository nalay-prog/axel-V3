# ════════════════════════════════════════════════════════════════════════════
# CONFIGURATION DARWIN AGENT - Solutions aux 4 problèmes de performance
# ════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════════════
# 1️⃣ ANTHROPIC API KEY - Solution au problème "anthropic_api_key_missing"
# ════════════════════════════════════════════════════════════════════════════
# ❌ NE PAS utiliser : "...", "xxx", "your_key", "sk-...", "replace_me"
# ✅ Obtenir votre clé : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_ACTUAL_KEY_HERE

# Modèle Claude à utiliser (par défaut: claude-sonnet-4-6)
CLAUDE_OPTIMIZED_MODEL=claude-sonnet-4-6

# Optimisation : réduire les tokens pour les réponses rapides
CLAUDE_OPTIMIZED_MAX_TOKENS=900
CLAUDE_OPTIMIZED_TEMPERATURE=0.2

# ⏱️ Timeout critique pour éviter les réponses > 15s
CLAUDE_OPTIMIZED_TIMEOUT_SECONDS=15

# ════════════════════════════════════════════════════════════════════════════
# 2️⃣ WEB SEARCH - Solution au problème "no_results_strict_realtime"
# ════════════════════════════════════════════════════════════════════════════

# Mode strict_realtime: si désactivé, ne bloque plus quand aucun résultat web
# RECOMMANDÉ: false pour réduire les warnings et améliorer le fallback
WEB_STRICT_REALTIME=false

# Nombre total de résultats à retourner (réduire = plus rapide)
WEB_MAX_RESULTS=5

# Nombre de tentatives avant fallback (réduire pour gagner du temps)
WEB_SEARCH_RETRY_ATTEMPTS=1

# ✅ Toujours activer le fallback à DuckDuckGo (gratuit, rapide)
WEB_FALLBACK_TO_DDGS=true

# Clés de recherche (optionnelles - la première disponible est utilisée)
SERPAPI_API_KEY=
SERPER_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ════════════════════════════════════════════════════════════════════════════
# 3️⃣ INTENT DETECTION - Solution aux intentions ambigues
# ════════════════════════════════════════════════════════════════════════════

# Activer le cache pour les intentions détectées (réduit CPU + temps)
INTENT_CACHE_ENABLED=true
INTENT_CACHE_TTL_SECONDS=3600

# Threshold pour considérer une intention comme "ambigüe"
# Réduire cette valeur = moins de clarifications demandées
INTENT_AMBIGUITY_THRESHOLD=3

# Nombre max de domaines avant de déclencher clarification
# RECOMMANDÉ: 2 (au lieu de 5+) pour être plus strict sur les intentions claires
INTENT_MAX_DOMAINS_BEFORE_CLARIFICATION=2

# ════════════════════════════════════════════════════════════════════════════
# 4️⃣ PERFORMANCE - Solution au problème "response_time_seconds > 15"
# ════════════════════════════════════════════════════════════════════════════

# Activations des optimisations
WEB_USE_PRIORITIZED_SEARCH=true        # Prioriser les domaines fiables
WEB_USE_CLAUDE_OPTIMIZED=true          # Claude optimisé au lieu du fallback
WEB_USE_ROUTER_FINALIZER_CHECKER=true  # Router intelligent
WEB_USE_CABINET_PIPELINE=true          # Pipeline cabinet

# Timeout global pour tout l'agent (en secondes)
AGENT_GLOBAL_TIMEOUT_SECONDS=18

# Réduction du nombre de résultats vectoriels pour accélérer
VECTOR_K_RESULTS=3

# Réduction du nombre de résultats SQL/KPI
SQL_KPI_MAX_RESULTS=3

# ════════════════════════════════════════════════════════════════════════════
# MONITORING & DEBUGGING
# ════════════════════════════════════════════════════════════════════════════

# Niveau de log
LOG_LEVEL=INFO

# Activer les métriques de performance
METRICS_ENABLED=true

# ════════════════════════════════════════════════════════════════════════════
# NOTES IMPORTANTES
# ════════════════════════════════════════════════════════════════════════════
#
# 📋 CHECK-LIST POUR RÉSOUDRE LES 4 PROBLÈMES :
#
# ❌ anthropic_api_key_missing :
#    1. Copier votre clé depuis https://console.anthropic.com/
#    2. Pas de caractères spéciaux après la clé
#    3. Relancer l'app après modification du .env
#    → VÉRIFIER : curl -H "Authorization: Bearer $ANTHROPIC_API_KEY" https://api.anthropic.com/v1/models
#
# ❌ no_results_strict_realtime :
#    1. Mettre WEB_STRICT_REALTIME=false (permettre le fallback)
#    2. Réduire WEB_SEARCH_RETRY_ATTEMPTS à 1
#    3. Activer WEB_FALLBACK_TO_DDGS=true
#    → RÉSULTAT : Le système répondra toujours, même sans source web premium
#
# ⚠️ clarification_requested (intentions ambigues) :
#    1. Réduire INTENT_MAX_DOMAINS_BEFORE_CLARIFICATION à 2
#    2. Augmenter INTENT_AMBIGUITY_THRESHOLD (plus permissif sur l'ambigüité)
#    3. Activer INTENT_CACHE_ENABLED=true
#    → RÉSULTAT : Moins de "questions à préciser", plus de réponses directes
#
# ⏱️ response_time_seconds > 15 (latence) :
#    1. CLAUDE_OPTIMIZED_TIMEOUT_SECONDS=15 (max strict)
#    2. WEB_SEARCH_RETRY_ATTEMPTS=1 (une seule tentative)
#    3. AGENT_GLOBAL_TIMEOUT_SECONDS=18 (total)
#    4. Réduire K_RESULTS pour moins de requêtes
#    → RÉSULTAT : Réponses < 12s en moyenne
#
# ════════════════════════════════════════════════════════════════════════════
